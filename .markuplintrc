{
  "specs": {
    "\\.[jt]sx?$": "@markuplint/react-spec"
  },
  "parser": {
    "\\.[jt]sx?$": "@markuplint/jsx-parser"
  },
  "extends": [
    "markuplint:recommended"
  ],
  "pretenders": [
    {
      "selector": "ServiceCard",
      "as": "li"
    },
    {
      "selector": "StrengthCard",
      "as": "li"
    },
    {
      "selector": "NavLink",
      "as": "li"
    }
  ],
  "overrideMode": "merge",
  "overrides": {
    "./src/components/*": {
      "rules": {
        "heading-levels": false
      }
    }
  }
}
