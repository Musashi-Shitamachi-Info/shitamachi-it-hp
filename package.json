{
  "name": "shitamachi-it-hp",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "build:cf": "opennextjs-cloudflare build",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm lint:next && pnpm lint:eslint && pnpm lint:markuplint",
    "lint:next": "next lint",
    "lint:eslint": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs",
    "lint:markuplint": "markuplint \"./src/**/*.{jsx,tsx}\"",
    "login": "wrangler login",
    "login:whoami": "wrangler whoami --json | jq -er '.accounts[0].name'",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@next/third-parties": "^16.0.0",
    "@opennextjs/cloudflare": "^1.16.5",
    "next": "^16.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@markuplint/jsx-parser": "^4.7.23",
    "@markuplint/react-spec": "^4.5.23",
    "@next/eslint-plugin-next": "^15.5.18",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^24.0.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.3",
    "eslint-config-next": "16.2.10",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "markuplint": "^4.14.1",
    "tailwindcss": "^4.2.0",
    "typescript": "^6.0.0",
    "wrangler": "^4.67.0"
  }
}
